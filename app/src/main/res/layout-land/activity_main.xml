<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_pitch_black"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/header_padding_horizontal"
        android:paddingEnd="@dimen/header_padding_horizontal"
        android:paddingTop="@dimen/header_padding_top"
        android:paddingBottom="@dimen/header_padding_bottom"
        android:background="@drawable/gradient_header_fade"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/main_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/netflix_red"
            android:textSize="@dimen/header_title_size"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.08"
            android:focusable="true"
            android:clickable="true"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/nav_categories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/categories"
            android:textColor="@color/text_gray_light"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:focusable="true"
            android:clickable="true"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/nav_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/nav_margin_end"
            android:text="@string/home"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.12"
            android:focusable="true"
            android:clickable="true"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            app:layout_constraintEnd_toStartOf="@+id/nav_categories"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/hub_rows"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingBottom="100dp"
        app:focusOutFront="true"
        app:focusOutEnd="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/main_header" />

    <!-- AdMob Banner Ad View Placeholder -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/ad_view_hub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-3940256099942544/6300978111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
